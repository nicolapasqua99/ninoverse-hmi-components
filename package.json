{
	"name": "@ninoverse/hmi-components",
	"version": "0.1.0",
	"description": "Foundation React components for the Ninoverse HMI",
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": ["dist"],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./styles.css": "./dist/index.css"
	},
	"scripts": {
		"dev": "vite build --watch",
		"build": "tsc -b && vite build",
		"lint": "biome check .",
		"format": "biome format --write ."
	},
	"peerDependencies": {
		"react": ">=18.0.0",
		"react-dom": ">=18.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "1.9.4",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"@vitejs/plugin-react": "^4.3.4",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"typescript": "^5.7.2",
		"vite": "^6.0.7",
		"vite-plugin-dts": "^4.4.0"
	}
}
